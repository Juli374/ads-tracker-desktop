{
  "env": {
    "browser": true,
    "es6": true,
    "node": true
  },
  "extends": [
    "eslint:recommended",
    "plugin:@typescript-eslint/eslint-recommended",
    "plugin:@typescript-eslint/recommended",
    "plugin:import/recommended",
    "plugin:import/electron",
    "plugin:import/typescript"
  ],
  "parser": "@typescript-eslint/parser",
  "overrides": [
    {
      "files": ["src/renderer/**/*.ts", "src/renderer/**/*.tsx"],
      "excludedFiles": [
        "src/renderer/**/__tests__/**",
        "src/renderer/i18n/resources/ru/**"
      ],
      "rules": {
        "no-restricted-syntax": [
          "error",
          {
            "selector": "Literal[value=/[\\u0400-\\u04FF\\u0500-\\u052F]/]",
            "message": "Cyrillic в renderer запрещён. Используй t() из i18n."
          },
          {
            "selector": "JSXText[value=/[\\u0400-\\u04FF\\u0500-\\u052F]/]",
            "message": "Cyrillic в JSX запрещён. Оберни в t() из i18n."
          },
          {
            "selector": "TemplateElement[value.raw=/[\\u0400-\\u04FF\\u0500-\\u052F]/]",
            "message": "Cyrillic в template literal запрещён. Используй t() из i18n."
          }
        ]
      }
    }
  ]
}
